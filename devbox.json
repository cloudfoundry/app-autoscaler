{
  "packages": {
    "github:joergdw/prspkgs#multiapps-cli-plugin": "",
    "github:joergdw/prspkgs#cloud-mta-build-tool": "",

    "path:.#app-autoscaler-cli-plugin": "",
    "path:.#log-cache-cli-plugin":      "",
    "path:.#uaa-cli":                   "",
    "path:.#flatten_json-schema":       "",

    "act": "0.2.89",
    "apple-sdk": {
      "version": "14.4",
      "platforms": [
        "aarch64-darwin"
      ]
    },
    "actionlint":           "1.7.12",
    "bash-language-server": "5.6.0",
    "bosh-cli":             "7.3.1",
    "cloudfoundry-cli":     "8.18.3",
    "coreutils":            "9.11",
    "credhub-cli":          "2.9.54",
    "curl":                 "8.17.0",
    "delve":                "1.26.3",
    "fly":                  "8.2.4",
    "gh":                   "2.95.0",
    "ginkgo":               "2.28.1",
    "gnumake":              "4.4.1",
    "gnused":               "4.9",
    "gnutar":               "1.35",
    "go-tools":             "2025.1.1",
    "golangci-lint":        "2.12.2",
    "gopls":                "0.22.0",
    "google-java-format":   "1.35.0",
    "gum":                  "0.17.0",
    "jdt-language-server":  "1.58.0",
    "jq":                   "1.8.1",
    "markdownlint-cli2":    "0.22.1",
    "maven":                "3.9.12",
    "mysql":                "10.6.12",
    "oha":                  "1.14.0",
    "openssl":              "3.6.0",
    "postgresql":           "17.10",
    "python":               "3.14.4",
    "redocly":              "2.17.0",
    "ripgrep":              "15.1.0",
    "shellcheck":           "0.11.0",
    "temurin-bin-21":       "21.0.3",
    "which":                "2.23",
    "xq-xml":               "1.4.0",
    "yq-go":                "4.53.3",
    "go":                   "1.26.2"
  },
  "shell": {
    "init_hook": [
      "export GOFIPS140=v1.0.0",
      "export GOTOOLCHAIN='local'",
      "install_plugin_if_needed() {",
      "  sum=$(sha1sum $(which $1) | cut --delimiter=' ' --fields='1')",
      "  cf plugins --checksum | grep --quiet ${sum} || cf install-plugin -f $(which $1)",
      "}",
      "install_plugin_if_needed 'app-autoscaler-cli-plugin'",
      "install_plugin_if_needed 'log-cache-cli'",
      "install_plugin_if_needed multiapps-cli-plugin"
    ]
  }
}
